{
  "name": "turborepo-starter",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:app1": "turbo run dev --filter=app1",
    "dev:app2": "turbo run dev --filter=app2",
    "build:dev": "turbo run build:dev",
    "deploy:dev": "turbo run deploy:dev",
    "build:prod": "turbo run build:prod",
    "deploy:prod": "turbo run deploy:prod",
    "lint": "turbo run lint",
    "fix": "turbo run lint -- --fix",
    "sgh": "simple-git-hooks",
    "create-app": "node scripts/create-app.js"
  },
  "devDependencies": {
    "@trs/lint": "workspace:*",
    "eslint": "10.5.0",
    "lint-staged": "latest",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "latest",
    "turbo": "latest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "**/{apps,packages}/*/src/**/*.{js,jsx,ts,tsx,vue}": "eslint --fix --no-warn-ignored",
    "**/{apps,packages}/*/*.{js,ts,mjs,json}": "eslint --fix --no-warn-ignored",
    "./*.{js,jsx,ts,tsx,mjs,json}": "eslint --fix --no-warn-ignored"
  }
}
